# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/

# Test / coverage / type / lint caches
.pytest_cache/
.coverage
.coverage.*
coverage.xml
*.cover
htmlcov/
.mypy_cache/
.ruff_cache/
.hypothesis/

# IDE / OS
.idea/
.vscode/
.DS_Store
Thumbs.db

# Local env files
*.env
!*.env.example

# Generated TLS/PKI material (gen_tak_certs.sh) — never commit private keys/certs.
# Globs cover a custom OUT_DIR too, not just the default flightctl/certs/.
flightctl/certs/
*.p12
*.key
*.crt
*.csr
*.srl

# Runtime / FPV capture artifacts (flight logger, log-convert, camera)
*.log
flight-logs/
*.parquet
*.mp4
*.h264
*.mkv

# Scout runtime artifacts (meshsa.scout): generated missions, SQLite stores, exports.
# DEM inputs (*.tif) are operator-supplied and intentionally not ignored here.
*.plan
*.waypoints
*.sqlite
*.sqlite3
scout-*.db

# Tooling
.python-version

# Agent / workflow scratch (superpowers SDD workspace: task briefs, review packages, ledger).
# Self-ignored by an inner .gitignore too; listed here so it's explicit at the repo root.
.superpowers/

# Build outputs
*.whl
*.tar.gz

# Inference / AI model cache
.inference_cache/