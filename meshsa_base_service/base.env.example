# /etc/meshsa/base.env  — base_node.py reads these (CLI flags would override).
# Mesh / radio
MESHSA_PORT=/dev/ttyUSB0
MESHSA_PORTNUM=256
MESHSA_MESH_REGION=US
# FreeTAKServer link (CoT over TCP)
MESHSA_FTS_HOST=127.0.0.1
MESHSA_FTS_PORT=8087
# Some FTS deployments want newline-framed CoT; set if needed:
# MESHSA_TCP_DELIMITER=\n
# Identity / position
MESHSA_UID=base-1
MESHSA_CALLSIGN=BASE1
MESHSA_LAT=37.0
MESHSA_LON=-122.0
# Cadence
MESHSA_PLI_INTERVAL_S=30
MESHSA_COT_STALE_S=120
