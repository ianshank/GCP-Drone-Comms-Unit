{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus data source scraping the meshsa /metrics endpoint.",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "9.0.0"
    }
  ],
  "title": "MeshSA Router & Transports (Golden Signals)",
  "description": "MeshSA gateway observability mapped to the four golden signals (Traffic, Errors, Saturation, Latency), plus an AI Inference row covering the meshsa_inference_* offline-drop/queue-depth/intake-drop/pending-task series. Metric names mirror packages/meshsa/src/meshsa/metrics.py; see ops/observability/README.md.",
  "uid": "meshsa-golden-signals",
  "tags": ["meshsa", "golden-signals", "observability"],
  "timezone": "",
  "schemaVersion": 39,
  "version": 2,
  "editable": true,
  "graphTooltip": 1,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {},
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "label": "Prometheus",
        "description": "Prometheus data source scraping the meshsa /metrics endpoint.",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "refresh": 1,
        "regex": "",
        "options": [],
        "includeAll": false,
        "multi": false,
        "skipUrlSync": false
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "Traffic",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "panels": []
    },
    {
      "id": 1,
      "type": "timeseries",
      "title": "Router throughput (rx / tx / forwarded)",
      "description": "Per-second rate of frames decoded (rx), sent (tx), and bridged onto other transports (forwarded).",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "fps",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["last", "max"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "rate(meshsa_rx_total[$__rate_interval])",
          "legendFormat": "rx"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "rate(meshsa_tx_total[$__rate_interval])",
          "legendFormat": "tx"
        },
        {
          "refId": "C",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "rate(meshsa_forwarded_total[$__rate_interval])",
          "legendFormat": "forwarded"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Inbound frames by transport",
      "description": "Per-second rate of frames received on each transport (meshsa_transport_rx_frames).",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "fps",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["last", "max"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "rate(meshsa_transport_rx_frames[$__rate_interval])",
          "legendFormat": "{{transport}}"
        }
      ]
    },
    {
      "id": 200,
      "type": "row",
      "title": "Errors",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 9
      },
      "panels": []
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Router error rate (undecodable / schema mismatch)",
      "description": "Per-second rate of frames dropped because they failed to decode (meshsa_dropped_undecodable_total) or used an unsupported wire schema (meshsa_schema_mismatch_total).",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 10
      },
      "fieldConfig": {
        "defaults": {
          "unit": "fps",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["last", "max"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "rate(meshsa_dropped_undecodable_total[$__rate_interval])",
          "legendFormat": "dropped_undecodable"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "rate(meshsa_schema_mismatch_total[$__rate_interval])",
          "legendFormat": "schema_mismatch"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Inbox-full drops by transport",
      "description": "Per-second rate of frames dropped because a transport inbox was full (meshsa_transport_dropped_inbox_full). Sustained non-zero values indicate the consumer cannot keep up.",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 10
      },
      "fieldConfig": {
        "defaults": {
          "unit": "fps",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["last", "max"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "rate(meshsa_transport_dropped_inbox_full[$__rate_interval])",
          "legendFormat": "{{transport}}"
        }
      ]
    },
    {
      "id": 300,
      "type": "row",
      "title": "Saturation",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 18
      },
      "panels": []
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Cumulative inbox-full drops by transport",
      "description": "Raw counter meshsa_transport_dropped_inbox_full. A rising line means the inbox queue is saturating and shedding frames.",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 19
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["last", "max"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "meshsa_transport_dropped_inbox_full",
          "legendFormat": "{{transport}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Cumulative reconnects by transport",
      "description": "Raw counter meshsa_transport_reconnects. Frequent reconnects signal an unstable link and serve as a latency/availability proxy (see Latency note).",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 19
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["last", "max"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "meshsa_transport_reconnects",
          "legendFormat": "{{transport}}"
        }
      ]
    },
    {
      "id": 400,
      "type": "row",
      "title": "Latency",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 27
      },
      "panels": []
    },
    {
      "id": 7,
      "type": "text",
      "title": "Latency: not yet instrumented",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 7,
        "w": 24,
        "x": 0,
        "y": 28
      },
      "options": {
        "mode": "markdown",
        "content": "### Latency is not yet instrumented\n\nMeshSA does **not** export an end-to-end latency metric today. There is no histogram (e.g. `meshsa_..._seconds_bucket`) emitted by `packages/meshsa/src/meshsa/metrics.py`, so a true latency panel cannot be drawn honestly.\n\n**Proxies in the meantime** (see the Saturation row):\n\n- **Reconnect frequency** — `rate(meshsa_transport_reconnects[$__rate_interval])` rising indicates an unstable link, which inflates delivery latency.\n- **Inbox-full drop rate** — `rate(meshsa_transport_dropped_inbox_full[$__rate_interval])` rising indicates queue saturation, which delays (or sheds) frames.\n\n**Future work (M3):** add a latency histogram in `metrics.py`, then replace this panel with a real p50/p95/p99 view. Until that metric exists, no latency series is plotted here — by design."
      }
    },
    {
      "id": 500,
      "type": "row",
      "title": "AI Inference (initiative E)",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 35
      },
      "panels": []
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Inference drops (offline / intake)",
      "description": "Per-second rate of envelopes dropped from the offline replay queue (meshsa_inference_offline_dropped_total) and shed at task intake (meshsa_inference_intake_dropped_total). Sustained non-zero => the edge node cannot keep up with inbound analysis load.",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 36
      },
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["last", "max"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "rate(meshsa_inference_offline_dropped_total[$__rate_interval])",
          "legendFormat": "offline_dropped"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "rate(meshsa_inference_intake_dropped_total[$__rate_interval])",
          "legendFormat": "intake_dropped"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Inference saturation (queue depth / pending tasks)",
      "description": "Instantaneous gauges: offline replay queue depth (meshsa_inference_offline_queue_depth) and in-flight analysis tasks (meshsa_inference_pending_tasks). Approaching the configured offline_queue_max / max_pending_tasks caps means shedding is imminent.",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 36
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["last", "max"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "meshsa_inference_offline_queue_depth",
          "legendFormat": "offline_queue_depth"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "meshsa_inference_pending_tasks",
          "legendFormat": "pending_tasks"
        }
      ]
    }
  ]
}
