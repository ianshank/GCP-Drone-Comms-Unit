# jetson-yolo-gcs configuration — copy to .env and edit.
# No secrets live here; every value has a safe default in core/config.py.

# --- App ---
APP_LOG_LEVEL=INFO
APP_JSON_LOGS=false

# --- Detection (YOLO / Hailo) ---
# Backend is auto-selected from the model file extension:
#   .pt / .engine / .onnx -> ultralytics    |    .hef -> hailo (stub)
YOLO_MODEL_PATH=yolov8n.pt
YOLO_CONFIDENCE=0.25
YOLO_IOU=0.45
YOLO_DEVICE=cpu
YOLO_IMGSZ=640

# --- Camera ---
# CAMERA_TYPE: usb | csi | rtsp
#   usb  -> CAMERA_SOURCE is a /dev/videoN path
#   csi  -> CAMERA_SOURCE is the CSI sensor-id (e.g. "0")
#   rtsp -> CAMERA_SOURCE is an rtsp:// URL
CAMERA_TYPE=usb
CAMERA_SOURCE=/dev/video0
CAMERA_WIDTH=1280
CAMERA_HEIGHT=720
CAMERA_FPS=30
# RTSP jitter-buffer latency in ms (0 = lowest latency). Only used when CAMERA_TYPE=rtsp.
CAMERA_RTSP_LATENCY_MS=0

# --- Streaming to GCS (QGroundControl) ---
# STREAM_ENCODER: x264 (CPU) | nvv4l2 (Jetson hardware encoder)
STREAM_ENABLED=true
STREAM_HOST=127.0.0.1
STREAM_PORT=5600
STREAM_ENCODER=x264
STREAM_BITRATE_KBPS=4000

# --- MAVLink LANDING_TARGET ---
# Disabled by default (charter carve-out: opt-in, advisory precision-landing only).
MAVLINK_ENDPOINT=udpout:127.0.0.1:14550
# This unit's own MAVLink IDs (companion computer), sent as the message source.
MAVLINK_SOURCE_SYSTEM=1
MAVLINK_SOURCE_COMPONENT=1
MAVLINK_ENABLE_LANDING_TARGET=false
# Comma-separated detection class names that trigger a LANDING_TARGET; empty = any.
MAVLINK_TARGET_CLASSES=
MAVLINK_FOV_X_RAD=1.204
MAVLINK_FOV_Y_RAD=0.733

# --- Pipeline loop policy ---
# Idle back-off between empty camera reads (seconds); non-zero avoids a 100% CPU spin.
PIPELINE_IDLE_POLL_S=0.01
# Stop after this many CONSECUTIVE empty reads. Leave unset to run until shutdown
# (tolerate transient camera timeouts indefinitely — the live default).
# PIPELINE_MAX_CONSECUTIVE_EMPTY=
# A frame must be read within this many seconds for the pipeline to report "live".
PIPELINE_LIVENESS_TIMEOUT_S=2.0
# Log a dropped-frame warning on the 1st drop and every Nth thereafter (anti-flood).
PIPELINE_DROP_LOG_EVERY=100
