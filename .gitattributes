# Normalize all text to LF in the repo; check out LF on every platform.
* text=auto eol=lf

# Treat known binary assets as binary (never normalize/diff as text).
*.stl   binary
*.zip   binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.whl   binary
*.pyd   binary
*.so    binary
*.gz    binary
