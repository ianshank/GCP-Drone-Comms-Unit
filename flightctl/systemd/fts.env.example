# /etc/flightctl/fts.env — FreeTAKServer config. Var names VERIFIED against the
# installed FreeTAKServer MainConfig (it honours these FTS_* environment variables).
# Keep all persistent data on the SSD so the eMMC root stays free.

# --- persistence (all on SSD) ---
FTS_PERSISTENCE_PATH=/mnt/ssd/data/fts
FTS_DB_PATH=/mnt/ssd/data/fts/FreeTAKServer.db
FTS_LOGFILE_PATH=/mnt/ssd/data/fts/Logs
FTS_DATAPACKAGE_PATH=/mnt/ssd/data/fts/DataPackages
FTS_CERTS_PATH=/mnt/ssd/data/fts/certs
FTS_CONFIG_PATH=/mnt/ssd/data/fts/FTSConfig.yaml

# --- network / identity (set FTS_*_ADDRESS to the Jetson LAN IP for remote ATAK) ---
FTS_USER_ADDRESS=0.0.0.0
FTS_API_ADDRESS=0.0.0.0
FTS_DP_ADDRESS=0.0.0.0
FTS_COT_PORT=8087
FTS_SSLCOT_PORT=8089
FTS_API_PORT=19023
FTS_CONNECTION_MESSAGE=flightctl FTS online

# --- behaviour ---
FTS_LOG_LEVEL=INFO
# false = boot headless on env+defaults (skips the interactive first-start wizard,
# which hangs under systemd). Verified to bring up CoT TCP :8087 on this box.
FTS_FIRST_START=false
# NOTE: FTS creates /opt/fts at import regardless of the above; symlink it to the
# SSD once (see the unit header) so nothing lands on the 28G eMMC root.
