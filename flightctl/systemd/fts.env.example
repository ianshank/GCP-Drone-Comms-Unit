# /etc/flightctl/fts.env — FreeTAKServer runtime config (verify names against your FTS version).
# Bind address ATAK clients connect to (the Jetson's LAN IP).
FTS_IP=0.0.0.0
# CoT streaming ports: 8087 plain TCP (simplest for a closed field net), 8089 SSL.
FTS_COT_PORT=8087
FTS_SSLCOT_PORT=8089
# REST API + web UI.
FTS_API_PORT=19023
# Data dir lives on the SSD (DB, logs, data packages).
FTS_DATA_DIR=/mnt/ssd/data/fts
