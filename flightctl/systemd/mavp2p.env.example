# /etc/flightctl/mavp2p.env — mavp2p endpoints (space-separated, one autopilot in, N consumers out).
# serial:<dev>:<baud>  udps:<bind>:<port> (any GCS dials in)  udpc:<host>:<port> (push to fixed host)
# Use the udev symlink (flightctl/udev) for a stable autopilot device path.
MAVP2P_ENDPOINTS=serial:/dev/flightctl-autopilot:57600 udps:0.0.0.0:14550
# Dev/sim (no hardware): consume the simulator instead of a serial link:
# MAVP2P_ENDPOINTS=udps:0.0.0.0:14550
