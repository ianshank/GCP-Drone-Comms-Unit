# SA Assistant (meshsa-llm) environment — copy to llm.env and edit.
# llm.env is git-ignored; this .example file holds NO real secrets.

# Required: your Anthropic API key.
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# Claude model id (override only if you have a reason to).
MESHSA_LLM_MODEL=claude-opus-4-8

# Where the assistant listens. Loopback by default — /chat discloses live
# positions and spends model tokens. To bind a non-loopback host you MUST set
# MESHSA_LLM_TOKEN (the server refuses to start otherwise) and then send
# `Authorization: Bearer <token>` on /chat.
MESHSA_LLM_HOST=127.0.0.1
MESHSA_LLM_PORT=8090
# MESHSA_LLM_TOKEN=replace-with-a-strong-random-secret

# Upstream read-only data sources (match start_all.sh endpoints).
MESHSA_MAVLINK2REST_URL=http://127.0.0.1:8088
MESHSA_DRONE_UID=uav-1
MESHSA_FTS_TRACKS_URL=http://127.0.0.1:19023/ManageGeoObject/getCoTGeoObject
